{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/assessments/(.*)",
      "dest": "/assessments/$1"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/index.html"
    }
  ]
}